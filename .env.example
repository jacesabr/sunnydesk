# SunnyDesk demo backend — environment variables.
# Copy to .env for local dev (never commit .env). On Render, set these as env vars.

# --- required: the voice call + the site-scrape extraction ---
OPENAI_API_KEY=sk-...

# --- self-serve scraper (the "build a demo for your hotel" flow) ---
# Firecrawl is the primary scraper; a 5-key pool rotates on rate-limit.
FIRECRAWL_API_KEY=fc-...
FIRECRAWL_API_KEY_POOL=fc-...,fc-...,fc-...
# Apify is the independent backup (needs a FUNDED token to actually serve —
# free tokens 403 "hard limit" when spent; the code rotates the pool regardless).
APIFY_TOKEN=apify_api_...
APIFY_TOKEN_POOL=apify_api_...,apify_api_...
# (No scraper keys at all still works: the chain falls back to a plain HTTP fetch.)

# --- optional overrides (defaults shown) ---
# OPENAI_REALTIME_MODEL=gpt-realtime-2.1
# OPENAI_REALTIME_VOICE=marin
# DEMO_EXTRACT_MODEL=gpt-4o-mini
# DEMO_DAILY_CALL_CAP=60
# DEMO_DAILY_BUILD_CAP=120
# PORT=8787   (Render sets this automatically)
